#!/bin/bash
set -x
choices=`echo "lock suspend suspend_and_lock bluetooth shutdown reboot setup launcher" | tr ' ' '\n'`

if command -v wofi
then 
    chosen=$(echo -e "$choices" | wofi --dmenu -i -p "Choose what to do ?" -l 7)
else
    chosen=$(echo -e "$choices" | dmenu -i -r -p 0x0)
fi

echo $chosen
case "$chosen" in
    lock) lock.sh;;
    suspend) systemctl suspend ;;
    suspend_and_lock) lock.sh && systemctl suspend ;;
    bluetooth) rofi-bluetooth ;;
    shutdown) ~/.local/bin/prompt "Do you want to shutdown ?" "shutdown now";;
    reboot) ~/.local/bin/prompt "Do you want to shutdown ?" "reboot";;
    setup) ~/.local/bin/prompt "Do you want to run ~/setup ?" "sh -c ~/setup";;
    launcher) fuzzel ;;
esac
